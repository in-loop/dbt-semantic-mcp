{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(just:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(pre-commit:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(bat:*)"
    ]
  },
  "env": {
    "JUST_UNSTABLE": "1"
  }
}
