# Normalize line endings: LF in repo, native on checkout (text=auto eol=lf
# means: detect text, store with LF, never auto-convert to CRLF).
* text=auto eol=lf

# Lockfiles: large + auto-generated. Mark linguist-generated so they
# don't dominate language stats and so PR diffs collapse them.
Cargo.lock         linguist-generated
uv.lock            linguist-generated
poetry.lock        linguist-generated
pnpm-lock.yaml     linguist-generated
package-lock.json  linguist-generated
yarn.lock          linguist-generated
go.sum             linguist-generated

# Documentation that's still source — keep visible.
*.md   linguist-detectable=true
*.mdx  linguist-detectable=true

# Binary types — declare so git doesn't try to merge / show as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.tgz   binary
*.gz    binary
*.xz    binary
*.zst   binary
*.7z    binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.mp3   binary
*.mp4   binary
*.mkv   binary
*.webm  binary
*.wasm  binary

# Containerfiles: small, source.
Containerfile  linguist-language=Dockerfile
*.containerfile linguist-language=Dockerfile

# Shell scripts: ensure LF even when authored on Windows checkouts.
*.sh   text eol=lf
*.bash text eol=lf
